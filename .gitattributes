# Normalize line endings to LF in the repo; check out as-is on all platforms.
* text=auto eol=lf

# Windows scripts may need CRLF on checkout — keep LF in repo, Git won't warn.
*.ps1 text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binaries — no line ending normalization.
*.pbf binary
*.mbtiles binary
*.jar binary
*.png binary
*.jpg binary
*.ico binary
